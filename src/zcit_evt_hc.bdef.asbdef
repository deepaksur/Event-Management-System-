projection;
strict ( 2 );
use draft;

define behavior for ZCIT_EVT_HC alias EventHeader
{
  use create;
  use update;
  use delete;
  use action Edit;
  use action Activate;
  use action Discard;
  use action Prepare;
  use action Resume;
  use association _session { create; with draft; }
}

define behavior for ZCIT_EVT_IC alias EventSession
{
  use update;
  use delete;
  use association _event { with draft; }
}